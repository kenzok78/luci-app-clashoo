#!/usr/bin/ucode

'use strict';

import { access, popen, glob } from 'fs';

/* 按优先级依次检测可用的二进制 */
const BINARY_PATHS = [
	'/usr/bin/mihomo',
	'/usr/bin/clash-meta',
	'/usr/bin/clash',
	'/etc/clash/clash',
	'/etc/clash/clashtun/clash',
];

function find_binary() {
	for (const path of BINARY_PATHS) {
		if (access(path, 'x')) return path;
	}
	return null;
}

/* 多个候选日志路径 */
const LOG_PATHS = [
	'/var/log/clash.log',
	'/var/log/clash/clash.log',
	'/tmp/clash.log',
	'/usr/share/clash/clash.txt',
];

/* clash 可能存放 YAML 的目录（最新优先）*/
const PROFILE_DIRS = [
	'/etc/clash/profiles',
	'/etc/clash',
];

const methods = {
	/* 版本信息 */
	version: {
		call: function () {
			const binary = find_binary();
			if (!binary) return { core: '', binary: '' };

			let core = '';
			const p = popen(`${binary} -v 2>&1 | head -1`);
			if (p) {
				core = trim(p.read('all'));
				p.close();
			}
			return { core: core, binary: binary };
		}
	},

	/* 运行状态，直接返回 boolean */
	status: {
		call: function () {
			return system('pgrep -x mihomo >/dev/null 2>&1'            ) == 0
			    || system('pgrep -x clash-meta >/dev/null 2>&1'        ) == 0
			    || system('service clash running >/dev/null 2>&1'      ) == 0;
		}
	},

	/* 热重载（不中断连接） */
	reload: {
		call: function () {
			return { success: system('service clash reload >/dev/null 2>&1') == 0 };
		}
	},

	/* 完全重启 */
	restart: {
		call: function () {
			return { success: system('service clash restart >/dev/null 2>&1') == 0 };
		}
	},

	/* 列出可用的 YAML 配置文件 */
	list_profiles: {
		call: function () {
			const profiles = [];
			for (const dir of PROFILE_DIRS) {
				if (!access(dir, 'r')) continue;
				const files = [
					...( glob(`${dir}/*.yaml`) || [] ),
					...( glob(`${dir}/*.yml`)  || [] ),
				];
				for (const f of files) {
					/* 只保留文件名，不含路径 */
					const name = replace(f, `${dir}/`, '');
					if (name && name != 'config.yaml' && !some(profiles, (x) => x == name)) {
						push(profiles, name);
					}
				}
				if (length(profiles) > 0) break;
			}
			return { profiles: profiles };
		}
	},

	/* 读取日志（最后 300 行） */
	read_log: {
		call: function () {
			for (const path of LOG_PATHS) {
				if (!access(path, 'r')) continue;
				const p = popen(`tail -300 '${path}'`);
				if (p) {
					const content = p.read('all');
					p.close();
					return { content: content };
				}
			}
			return { content: '' };
		}
	}
};

return { 'luci.clash': methods };
